# Copy this file to `.env` and fill in the values. NEVER commit `.env`.

# ---- Claude API (required for the agent) ----
# Get a key at https://console.anthropic.com  →  Settings  →  API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model IDs the agent uses. Swap here without touching code.
# Sonnet 4.6 = the agent's reasoning brain. Haiku 4.5 = cheap sub-tasks.
AGENT_MODEL=claude-sonnet-4-6
FAST_MODEL=claude-haiku-4-5

# ---- Postgres (local docker-compose defaults) ----
POSTGRES_USER=mealmind
POSTGRES_PASSWORD=mealmind
POSTGRES_DB=mealmind

# ---- Service wiring (docker-compose uses service names as hosts) ----
# Spring Boot connects to Postgres and to the AI service:
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/mealmind
AI_SERVICE_URL=http://ai-service:8000

# React (Vite) talks to the Spring Boot API. For local dev this is the host port.
VITE_API_BASE_URL=http://localhost:8080
